{
  "expo": {
    "name": "DetroGo",
    "slug": "DetroGo",
    "version": "alpha 0.0.3",
    "orientation": "portrait",
    "assetBundlePatterns": ["assets/routemap/**"],
    "icon": "./assets/icons/icon.png",
    "scheme": "detrogo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": {
        "light": "./assets/icons/ios-light.png",
        "dark": "./assets/icons/ios-dark.png",
        "tinted": "./assets/icons/ios-tinted.png"
      },
      "bundleIdentifier": "com.anshwadhwa.DetroGo"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/ic_launcher_foreground.png",
        "monochromeImage": "./assets/icons/ic_launcher_monochrome.png",
        "backgroundImage": "./assets/icons/ic_launcher_background.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "usesCleartextTraffic": true,
      "package": "com.anshwadhwa.DetroGo",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.POST_PROMOTED_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-live-updates",
        {
          "channelId": "detro-live",
          "channelName": "DetroGo Live Updates"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icons/ic_launcher_foreground.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      ["@maplibre/maplibre-react-native"],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/splash-icon-dark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/icons/splash-icon-light.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "31827b02-01b6-4027-a0ff-6701277af0bc"
      }
    }
  }
}
